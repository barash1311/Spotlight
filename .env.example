# ── Database ────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/portfolio_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Default Admin User (seeded on startup) ──────────────
SEED_DEFAULT_USER_ENABLED=true
SEED_DEFAULT_USER_USERNAME=admin
SEED_DEFAULT_USER_EMAIL=admin@example.com
SEED_DEFAULT_USER_PASSWORD=secure_password_here

# ── JWT ─────────────────────────────────────────────────
# Must be at least 64 characters long in hexadecimal format for HS384
JWT_SECRET=your_super_secret_jwt_key_here_must_be_long_and_secure_for_production
JWT_EXPIRY_MS=3600000

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. your front-end url)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-portfolio.com
